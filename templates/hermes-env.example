# Required for Grok-based simulation runs
XAI_API_KEY=your_xai_key_here

# Required for graph memory / relationship persistence
ZEP_API_KEY=your_zep_key_here

# Optional but recommended for stronger planner/analysis responses
OPENAI_API_KEY=your_openai_key_here

# Optional: non-default Hermes home
# HERMES_HOME=/path/to/hermes/home
